# Server
PORT=4000
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/yourapp

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-minimum-32-character-secret-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@yourapp.com

# AI (Gemini)
GEMINI_API_KEY=xxx

# Inngest (background jobs)
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=xxx

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Public URL of this backend (used for email open-tracking pixel links)
API_URL=http://localhost:4000

# Sentry (optional)
SENTRY_DSN=

# AWS S3 — resume uploads (optional; upload endpoint returns 503 until these are set).
# Leave AWS_ACCESS_KEY_ID/SECRET blank on EC2 if the instance has an IAM role with
# S3 access — the SDK picks that up automatically instead.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Optional: CloudFront (or other CDN) domain in front of the S3 bucket, e.g.
# https://d111111abcdef8.cloudfront.net — only use this if that distribution/bucket
# is publicly readable; otherwise leave blank to fall back to signed S3 URLs.
RESUME_CDN_URL=
