{
  "name": "your-app-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "dev:all": "concurrently -n api,worker -c blue,green \"npm:dev\" \"npm:dev:worker\"",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "mongoose": "^8.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "ioredis": "^5.3.0",
    "bullmq": "^5.7.0",
    "zod": "^3.22.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "@sentry/node": "^7.99.0",
    "resend": "^3.1.0",
    "@google/generative-ai": "^0.21.0",
    "stripe": "^14.20.0",
    "inngest": "^3.15.0",
    "express-rate-limit": "^7.2.0",
    "@upstash/ratelimit": "^1.1.0",
    "@upstash/redis": "^1.28.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.0",
    "multer": "^2.0.0",
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/multer": "^1.4.11",
    "tsx": "^4.7.0",
    "tsc-alias": "^1.8.8",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0"
  }
}
