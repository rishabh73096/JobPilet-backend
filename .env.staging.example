# Same shape as .env.example — this is what goes on the staging EC2 box (or wherever
# staging runs). NODE_ENV=staging enables Sentry (if SENTRY_DSN is set) while keeping
# behavior otherwise identical to production. Use a separate MongoDB database/Stripe
# test keys/etc. so staging traffic never touches production data.

# Server
PORT=4000
NODE_ENV=staging

# Database — separate DB name from production, same or different cluster
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/yourapp-staging

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-minimum-32-character-secret-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Stripe — use test-mode keys on staging
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@staging.yourapp.com

# AI (Gemini)
GEMINI_API_KEY=xxx

# Inngest (background jobs)
INNGEST_EVENT_KEY=xxx
INNGEST_SIGNING_KEY=xxx

# Frontend URL (for CORS) — your staging frontend's URL
FRONTEND_URL=https://staging.your-domain.com

# Public URL of this backend
API_URL=https://api-staging.your-domain.com

# Sentry — use a separate Sentry project (or the same one, tagged by environment)
SENTRY_DSN=

# AWS S3 — resume uploads
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
RESUME_CDN_URL=
